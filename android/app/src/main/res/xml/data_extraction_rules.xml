<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ (API 31+). Backup is already disabled via
     android:allowBackup="false"; these rules additionally exclude the app's
     private data from cloud backup and device-to-device transfer/cloning, so
     game stats, settings, and the ad-free flag can't be lifted out of the app
     sandbox by either path. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
